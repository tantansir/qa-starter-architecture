{
  "name": "qa-starter-architecture",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/src"
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "QA starter local HTTP server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "PYTHONPATH=src python -m unittest discover -s tests -v"
}
